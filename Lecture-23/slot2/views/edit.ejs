<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>edit</title>
</head>
<body>
    <h1> edit Product : <%= r[0].P_id %></h1>
    <form action="/product/<%= r[0].P_id%>?_method=PUT" method="Post">
        <label for="">Name</label>
        <input type="text" name="E_name" id="" value="<%=r[0].P_name%>">
        <br>
         <label for="">Price</label>
        <input type="number" name="E_price" id="" value="<%=r[0].P_price%>">
        <br>
         <label for="">qty</label>
        <input type="number" name="E_qty" id="" value="<%=r[0].P_qty%>">
        <br>
        <label for="">Img URl</label>
        <input type="text" name="E_img" id="" value="<%=r[0].P_img%>">
        <br>
        <label for="">Product id</label>
        <input type="text" name="E_id" id="" value="<%= r[0].P_id %>">
        <br>
        <button type="submit">EDIT</button>
    </form>
</body>
</html>